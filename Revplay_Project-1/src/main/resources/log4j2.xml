<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

	<Appenders>

		<Console name="ConsoleAppender" target="SYSTEM_OUT">
			<PatternLayout
				pattern="%d{HH:mm:ss} %highlight{%-5level} %logger{36} - %msg%n" />
		</Console>

		<!-- File Appender (for your service logs only) -->
		<RollingFile name="FileAppender"
			fileName="logs/service.log"
			filePattern="logs/service-%d{yyyy-MM-dd}-%i.log.gz">

			<PatternLayout>
				<Pattern>
					%d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %logger{36} - %msg%n
				</Pattern>
			</PatternLayout>

			<Policies>
				<TimeBasedTriggeringPolicy interval="1" />
				<SizeBasedTriggeringPolicy size="10 MB" />
			</Policies>

			<DefaultRolloverStrategy max="30" />
		</RollingFile>

	</Appenders>

	<Loggers>

		<!-- 🔥 Your Service Package → Log to File Only -->
		<Logger name="com.example.demo.service.impl"
			level="debug"
			additivity="false">
			<AppenderRef ref="FileAppender" />
		</Logger>

		<!-- Root Logger → Console Only -->
		<Root level="info">
			<AppenderRef ref="ConsoleAppender" />
		</Root>

	</Loggers>

</Configuration>